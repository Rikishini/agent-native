# ─── Required in production ──────────────────────────────────────────────────
# Copy these into Railway → Service → Variables

# Anthropic (замінити на свій ключ)
ANTHROPIC_API_KEY=sk-ant-...YOUR_KEY_HERE...

# Auth — session cookies & HMAC signing
BETTER_AUTH_SECRET=b2423c64aa586ab48b53b5acd309e4974d0982830d9c70d998874ae305600127

# Public URL of this app (set AFTER Railway assigns a domain)
# e.g. BETTER_AUTH_URL=https://dispatch-production-xxxx.up.railway.app
BETTER_AUTH_URL=https://REPLACE_AFTER_DEPLOY.up.railway.app

# OAuth state envelope signing
OAUTH_STATE_SECRET=590a907c802cc0b938dd95d23b4ebbfe29805c4a97cbc3c3a63b982b90893bbd

# Inter-app A2A signed RPC (must match across all services)
A2A_SECRET=056dad606140adf3b93f4c57c3642dfae4eabbf7b529fed85141e3826750fecd

# Encrypted-at-rest secrets vault
SECRETS_ENCRYPTION_KEY=4a64271d06b93719363e22ae5b6c03396ffa5829b686ef23c4450ff37a596062

# ─── Database ────────────────────────────────────────────────────────────────
# Add a PostgreSQL plugin in Railway and copy its DATABASE_URL here.
# Without this, the app falls back to SQLite (resets on every deploy).
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB

# ─── Optional: per-app base path (set by workspace deploy, leave blank for single app)
# APP_BASE_PATH=/dispatch
